# Environment configurations (local or docker)
ENVIRONMENT=local
LOG_LEVEL=INFO

# Groq API Configuration (Enables conversational NLP intelligence)
GROQ_API_KEY=your_groq_api_key_here

# Data science & database settings
DATA_DIR=data
MODELS_DIR=models
DATABASE_URL=sqlite:///data/credit_risk.db

# Random seed for reproducibility
RANDOM_STATE=42
